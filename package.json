{
  "name": "deepseek-v4-deconstruction-lab",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Interactive puzzle-first tutorial for DeepSeek-V4 model.py + kernel.py.",
  "scripts": {
    "build": "python3 tools/build_tutorial.py",
    "dev": "python3 tools/build_tutorial.py && node site/dev-server.mjs",
